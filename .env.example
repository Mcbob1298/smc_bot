# V1 SCOPE: XAUUSD only. BTC/Binance variables archived (see _archived/README.md).

# =============================================================================
# MetaTrader 5 connection
# =============================================================================
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_LOGIN=12345678
MT5_PASSWORD=your_password_here
MT5_SERVER=ICMarkets-Demo

# Override broker-specific symbol names (JSON dict)
# Example for brokers using GOLD instead of XAUUSD:
# MT5_SYMBOL_MAP={"XAUUSD": "GOLD"}
MT5_SYMBOL_MAP={"XAUUSD": "XAUUSD"}

# =============================================================================
# Application settings
# =============================================================================
LOG_LEVEL=INFO
DATA_DIR=data/parquet
LOG_DIR=logs

# Historical data start date (ISO format)
DATA_START_DATE=2021-01-01

# Timezone for killzones and session logic
TIMEZONE=Europe/Paris
